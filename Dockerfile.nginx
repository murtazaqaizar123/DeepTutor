FROM nginx:alpine
RUN rm /etc/nginx/conf.d/default.conf
RUN echo 'server { \
    listen 80; \
    server_name deeptutor.q-solutions.pk; \
    location / { \
        proxy_pass http://deeptutor:3782; \
        proxy_set_header Host $host; \
        proxy_set_header X-Real-IP $remote_addr; \
    } \
} \
server { \
    listen 80; \
    server_name api-deeptutor.q-solutions.pk; \
    location / { \
        if ($request_method = "OPTIONS") { \
            add_header "Access-Control-Allow-Origin" "https://deeptutor.q-solutions.pk" always; \
            add_header "Access-Control-Allow-Methods" "GET, POST, OPTIONS, PUT, DELETE" always; \
            add_header "Access-Control-Allow-Headers" "Content-Type, Authorization, X-Requested-With" always; \
            return 204; \
        } \
        add_header "Access-Control-Allow-Origin" "https://deeptutor.q-solutions.pk" always; \
        proxy_pass http://deeptutor:8001; \
        proxy_set_header Host $host; \
        proxy_set_header X-Real-IP $remote_addr; \
    } \
}' > /etc/nginx/conf.d/default.conf
